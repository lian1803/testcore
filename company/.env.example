# 사용자 설정 (필수)
OWNER_NAME=여기에_본인_이름_입력

# AI 모델 API 키
ANTHROPIC_API_KEY=sk-ant-여기에_API_키_입력
OPENAI_API_KEY=sk-proj-여기에_API_키_입력
GOOGLE_API_KEY=AIzaSy여기에_API_키_입력
PERPLEXITY_API_KEY=pplx-여기에_API_키_입력

# 콘텐츠 자동 발행 설정 ═════════════════════════════

# Gmail 발송 (선택 — 이메일 DM용)
GMAIL_ADDRESS=여기에_이메일_입력
GMAIL_APP_PASSWORD=여기에_앱_비밀번호_입력
# 설정 방법: https://support.google.com/accounts/answer/185833 (앱 비밀번호 생성)

# 네이버 블로그 API (선택 — 블로그 자동 발행용)
NAVER_BLOG_CLIENT_ID=여기에_클라이언트ID_입력
NAVER_BLOG_CLIENT_SECRET=여기에_클라이언트시크릿_입력
NAVER_BLOG_ACCESS_TOKEN=여기에_액세스토큰_입력
NAVER_BLOG_ID=여기에_블로그ID_입력
# 설정 방법: SETUP_PUBLISH.md 참고

# Meta Graph API (선택 — 인스타그램 자동 발행용)
META_ACCESS_TOKEN=여기에_액세스토큰_입력
INSTAGRAM_BUSINESS_ACCOUNT_ID=여기에_계정ID_입력
# 설정 방법: https://developers.facebook.com/docs/instagram-api (Business 계정 필수)

# 디스코드 알림 (선택)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL

# 디스코드 봇 (선택)
DISCORD_BOT_TOKEN=여기에_봇_토큰_입력
DISCORD_LIAN_USER_ID=여기에_리안_유저ID_입력
DISCORD_CHANNEL_ID=여기에_채널ID_입력

# Meta Ads Library API (필수 — 광고 분석 기능)
META_ACCESS_TOKEN=여기에_토큰_입력
INSTAGRAM_BUSINESS_ACCOUNT_ID=여기에_계정ID_입력

# Cloudflare 배포 (선택사항)
CLOUDFLARE_API_TOKEN=여기에_토큰_입력
CLOUDFLARE_ACCOUNT_ID=여기에_계정ID_입력
CF_PROJECT_NAME=your-project-name

# 크론 모니터링 (선택)
PROJECT_URL=https://your-project.cloudflare.app

# GitHub MCP (선택)
GITHUB_PERSONAL_ACCESS_TOKEN=여기에_토큰_입력

# Sentry 에러 트래킹 (선택)
SENTRY_AUTH_TOKEN=여기에_토큰_입력

# Supabase DB (선택)
SUPABASE_URL=여기에_프로젝트_URL
SUPABASE_SERVICE_ROLE_KEY=여기에_서비스_롤_키

# Langfuse LLM 모니터링 (선택 — 키 없으면 로컬 로그만 저장)
LANGFUSE_PUBLIC_KEY=여기에_퍼블릭_키_입력
LANGFUSE_SECRET_KEY=여기에_시크릿_키_입력
# 설정 방법: https://langfuse.com/docs/get-started (계정 생성 후 API 키 복사)
