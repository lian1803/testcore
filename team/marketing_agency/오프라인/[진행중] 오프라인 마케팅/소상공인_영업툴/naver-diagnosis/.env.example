# Naver Search API (Local Search)
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Naver Search Ads API (Keyword Tool)
NAVER_AD_CUSTOMER_ID=your_customer_id
NAVER_AD_ACCESS_LICENSE=your_access_license
NAVER_AD_SECRET_KEY=your_secret_key

# Database
DATABASE_URL=sqlite+aiosqlite:///./diagnosis.db
# 개발 단계: true 설정 시 서버 시작 시 테이블 삭제 후 재생성 (스키마 변경 반영)
DB_RESET=false

# Server
HOST=0.0.0.0
PORT=8000

# AI 분석 (Claude + Gemini) — 선택사항
ANTHROPIC_API_KEY=your_anthropic_api_key
GOOGLE_API_KEY=your_google_api_key

# 결제 링크 (5차 메시지에서 사용) — 실제 카카오페이/네이버페이 링크로 설정
PAYMENT_LINK=https://pay.naver.com/
